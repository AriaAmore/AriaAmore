<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Aria Amore · Xavier Williams · Sopranist Countertenor</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Cormorant+SC:wght@300;400;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#C9A84C;
  --gold2:#E8C96A;
  --gold3:#F5E4A0;
  --black:#080604;
  --near-black:#0F0D0A;
  --dark:#1A1510;
  --mid:#6A5A3A;
  --cream:#F5F0E8;
  --white:#FDFBF8;
}

html{scroll-behavior:smooth;font-size:16px}
body{
  background:var(--black);
  color:var(--cream);
  font-family:'Cormorant Garamond',serif;
  overflow-x:hidden;
  cursor:none;
}

/* ── CUSTOM CURSOR ── */
.cursor{
  position:fixed;width:12px;height:12px;
  background:var(--gold);
  border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  transition:transform 0.1s ease,width 0.3s ease,height 0.3s ease,opacity 0.3s;
  mix-blend-mode:difference;
}
.cursor-ring{
  position:fixed;width:40px;height:40px;
  border:1px solid rgba(201,168,76,0.5);
  border-radius:50%;pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:transform 0.15s ease,width 0.3s ease,height 0.3s ease;
}
body:hover .cursor{opacity:1}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  padding:24px 48px;
  display:flex;align-items:center;justify-content:space-between;
  background:linear-gradient(to bottom,rgba(8,6,4,0.95),transparent);
  transition:background 0.4s;
}
nav.scrolled{background:rgba(8,6,4,0.97);border-bottom:1px solid rgba(201,168,76,0.15)}
.nav-logo{
  font-family:'Cormorant SC',serif;
  font-size:15px;letter-spacing:0.4em;
  color:var(--gold);text-decoration:none;
}
.nav-links{display:flex;gap:40px;list-style:none}
.nav-links a{
  font-family:'Cormorant SC',serif;font-size:10px;
  letter-spacing:0.35em;color:var(--cream);
  text-decoration:none;opacity:0.7;
  transition:opacity 0.3s,color 0.3s;
}
.nav-links a:hover{opacity:1;color:var(--gold)}
.nav-cta{
  font-family:'Cormorant SC',serif;font-size:10px;
  letter-spacing:0.35em;color:var(--black);
  background:var(--gold);
  padding:10px 24px;text-decoration:none;
  transition:background 0.3s,transform 0.2s;
}
.nav-cta:hover{background:var(--gold2);transform:translateY(-1px)}

/* ── HERO ── */
#home{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background-image:url('data:image/jpeg;base64,');
  background-size:cover;
  background-position:center 20%;
  background-repeat:no-repeat;
  animation:breathe 8s ease-in-out infinite alternate;
}
.hero-bg::after{
  content:'';position:absolute;inset:0;
  background:
    linear-gradient(to bottom, rgba(8,6,4,0.55) 0%, rgba(8,6,4,0.3) 40%, rgba(8,6,4,0.7) 100%),
    radial-gradient(ellipse at 20% 50%,rgba(201,168,76,0.08) 0%,transparent 60%);
}
@keyframes breathe{
  from{opacity:0.7;transform:scale(1)}
  to{opacity:1;transform:scale(1.05)}
}

/* Dramatic diagonal lines */
.hero-lines{
  position:absolute;inset:0;overflow:hidden;opacity:0.06;
}
.hero-lines::before{
  content:'';position:absolute;
  top:-50%;left:30%;
  width:1px;height:200%;
  background:linear-gradient(to bottom,transparent,var(--gold),transparent);
  transform:rotate(15deg);
}
.hero-lines::after{
  content:'';position:absolute;
  top:-50%;left:60%;
  width:1px;height:200%;
  background:linear-gradient(to bottom,transparent,var(--gold),transparent);
  transform:rotate(15deg);
}

.hero-content{
  position:relative;z-index:2;
  text-align:center;
  padding:0 40px;
  max-width:1100px;
}

.hero-pretitle{
  font-family:'Cormorant SC',serif;
  font-size:11px;letter-spacing:0.6em;
  color:var(--gold);opacity:0;
  animation:fadeUp 1s ease 0.3s forwards;
  margin-bottom:32px;
}

.hero-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(64px,10vw,140px);
  font-weight:900;font-style:italic;
  line-height:0.9;
  color:var(--white);
  opacity:0;
  animation:fadeUp 1s ease 0.6s forwards;
  margin-bottom:16px;
  letter-spacing:-0.02em;
}
.hero-title .gold{color:var(--gold)}
.hero-title .outline{
  -webkit-text-stroke:2px var(--gold);
  color:transparent;
}

.hero-subtitle{
  font-family:'Playfair Display',serif;
  font-size:clamp(18px,3vw,32px);
  font-style:italic;font-weight:400;
  color:rgba(245,240,232,0.6);
  opacity:0;
  animation:fadeUp 1s ease 0.9s forwards;
  margin-bottom:48px;
  letter-spacing:0.05em;
}

.hero-divider{
  display:flex;align-items:center;justify-content:center;
  gap:16px;margin-bottom:48px;
  opacity:0;animation:fadeUp 1s ease 1.1s forwards;
}
.hero-divider-line{width:80px;height:1px;background:linear-gradient(90deg,transparent,var(--gold))}
.hero-divider-line.right{background:linear-gradient(90deg,var(--gold),transparent)}
.hero-divider-gem{
  width:8px;height:8px;background:var(--gold);
  transform:rotate(45deg);
}

.hero-buttons{
  display:flex;gap:20px;justify-content:center;flex-wrap:wrap;
  opacity:0;animation:fadeUp 1s ease 1.3s forwards;
}
.btn-primary{
  font-family:'Cormorant SC',serif;font-size:11px;
  letter-spacing:0.4em;color:var(--black);
  background:var(--gold);padding:18px 40px;
  text-decoration:none;
  transition:all 0.3s ease;
  position:relative;overflow:hidden;
}
.btn-primary::before{
  content:'';position:absolute;inset:0;
  background:var(--gold2);transform:translateX(-100%);
  transition:transform 0.3s ease;
}
.btn-primary:hover::before{transform:translateX(0)}
.btn-primary span{position:relative;z-index:1}
.btn-ghost{
  font-family:'Cormorant SC',serif;font-size:11px;
  letter-spacing:0.4em;color:var(--gold);
  border:1px solid rgba(201,168,76,0.5);
  padding:18px 40px;text-decoration:none;
  transition:all 0.3s ease;
}
.btn-ghost:hover{background:rgba(201,168,76,0.1);border-color:var(--gold)}

/* ── SCROLL INDICATOR ── */
.scroll-indicator{
  position:absolute;bottom:40px;left:50%;
  transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  opacity:0;animation:fadeIn 1s ease 2s forwards;
}
.scroll-indicator span{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.4em;color:rgba(201,168,76,0.5);
}
.scroll-line{
  width:1px;height:60px;
  background:linear-gradient(to bottom,var(--gold),transparent);
  animation:scrollPulse 2s ease infinite;
}
@keyframes scrollPulse{
  0%{transform:scaleY(0);transform-origin:top}
  50%{transform:scaleY(1);transform-origin:top}
  51%{transform:scaleY(1);transform-origin:bottom}
  100%{transform:scaleY(0);transform-origin:bottom}
}

/* ── SECTIONS BASE ── */
section{padding:120px 48px}
.section-inner{max-width:1200px;margin:0 auto}

.overline{
  font-family:'Cormorant SC',serif;font-size:10px;
  letter-spacing:0.5em;color:var(--gold);
  display:block;margin-bottom:24px;
}
.section-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(40px,5vw,72px);
  font-weight:700;line-height:1;
  color:var(--white);margin-bottom:32px;
}
.section-title em{font-style:italic;color:var(--gold)}
.section-title .outline{
  -webkit-text-stroke:1px rgba(201,168,76,0.6);
  color:transparent;
}

/* ── ABOUT ── */
#about{
  background:var(--near-black);
  position:relative;overflow:hidden;
}
#about::before{
  content:'';position:absolute;
  right:-200px;top:50%;transform:translateY(-50%);
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(201,168,76,0.07),transparent 70%);
  pointer-events:none;
}

.about-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:80px;align-items:center;
}
.about-image-frame{
  position:relative;
}
.about-image-box{
  width:100%;aspect-ratio:3/4;
  background:linear-gradient(135deg,var(--dark),var(--near-black));
  border:1px solid rgba(201,168,76,0.2);
  position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.about-image-placeholder{
  font-family:'Playfair Display',serif;
  font-size:80px;font-style:italic;
  color:rgba(201,168,76,0.15);
  text-align:center;line-height:1;
  user-select:none;
}
.about-image-box::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(to top,rgba(8,6,4,0.6),transparent 50%);
}
/* Decorative corner accents */
.about-image-frame::before{
  content:'';position:absolute;
  top:-16px;left:-16px;right:16px;bottom:16px;
  border:1px solid rgba(201,168,76,0.2);
  pointer-events:none;z-index:0;
}

.about-text{}
.about-body{
  font-size:18px;line-height:2;
  color:rgba(245,240,232,0.7);
  margin-bottom:32px;
}
.about-credentials{
  list-style:none;
  display:flex;flex-direction:column;gap:12px;
  margin-bottom:40px;
}
.about-credentials li{
  display:flex;align-items:flex-start;gap:16px;
  font-size:15px;color:rgba(245,240,232,0.6);
  line-height:1.5;
}
.about-credentials li::before{
  content:'◆';color:var(--gold);font-size:8px;
  margin-top:5px;flex-shrink:0;
}
.about-stat-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:1px;background:rgba(201,168,76,0.15);
  margin-top:48px;
}
.about-stat{
  background:var(--near-black);
  padding:24px 20px;text-align:center;
}
.about-stat-num{
  font-family:'Playfair Display',serif;
  font-size:40px;font-weight:700;font-style:italic;
  color:var(--gold);line-height:1;margin-bottom:8px;
}
.about-stat-label{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.3em;color:rgba(245,240,232,0.4);
}

/* ── WEDDING ── */
#wedding{
  background:var(--black);
  position:relative;
}
.wedding-hero-text{
  text-align:center;max-width:800px;margin:0 auto 80px;
}
.wedding-hero-text p{
  font-size:20px;font-style:italic;
  color:rgba(245,240,232,0.6);line-height:1.9;
}

.wedding-packages{
  display:grid;gap:2px;
}
.w-pkg{
  display:grid;grid-template-columns:300px 1fr;
  background:rgba(245,240,232,0.02);
  border:1px solid rgba(201,168,76,0.1);
  overflow:hidden;
  transition:border-color 0.4s,background 0.4s;
}
.w-pkg:hover{
  border-color:rgba(201,168,76,0.4);
  background:rgba(201,168,76,0.03);
}
.w-pkg.featured{border-color:rgba(201,168,76,0.3)}
.w-pkg-left{
  padding:48px 40px;
  background:rgba(201,168,76,0.04);
  border-right:1px solid rgba(201,168,76,0.1);
  display:flex;flex-direction:column;justify-content:center;
}
.w-pkg-tier{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.4em;color:var(--gold);margin-bottom:12px;
}
.w-pkg-name{
  font-family:'Playfair Display',serif;
  font-size:28px;font-style:italic;font-weight:700;
  color:var(--white);margin-bottom:20px;line-height:1.1;
}
.w-pkg-price{
  font-family:'Playfair Display',serif;
  font-size:42px;font-weight:400;font-style:italic;
  color:var(--gold);line-height:1;
}
.w-pkg-price sup{font-size:20px;vertical-align:top;margin-top:12px}
.w-pkg-price small{font-size:14px;color:var(--mid);font-style:normal;font-family:'Cormorant Garamond',serif}
.w-pkg-right{
  padding:48px 56px;
  display:flex;flex-direction:column;justify-content:center;
}
.w-pkg-desc{
  font-size:18px;font-style:italic;
  color:rgba(245,240,232,0.5);
  margin-bottom:24px;line-height:1.7;
}
.w-pkg-includes{list-style:none;display:flex;flex-direction:column;gap:10px}
.w-pkg-includes li{
  font-size:15px;color:rgba(245,240,232,0.6);
  padding-left:20px;position:relative;line-height:1.5;
}
.w-pkg-includes li::before{
  content:'—';position:absolute;left:0;color:var(--gold);
}
.most-requested{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.3em;color:var(--gold);
  border:1px solid rgba(201,168,76,0.4);
  padding:4px 12px;display:inline-block;
  margin-bottom:16px;
}

.ensemble-add{
  margin-top:48px;
  display:grid;grid-template-columns:1fr 1fr;gap:2px;
}
.ensemble-card{
  background:rgba(245,240,232,0.02);
  border:1px solid rgba(201,168,76,0.1);
  padding:40px;
  transition:border-color 0.3s,background 0.3s;
}
.ensemble-card:hover{
  border-color:rgba(201,168,76,0.3);
  background:rgba(201,168,76,0.03);
}
.e-role{font-family:'Cormorant SC',serif;font-size:9px;letter-spacing:0.4em;color:var(--gold);margin-bottom:12px}
.e-name{font-family:'Playfair Display',serif;font-size:26px;font-style:italic;color:var(--white);margin-bottom:12px}
.e-price{font-family:'Playfair Display',serif;font-size:32px;font-style:italic;color:var(--gold);margin-bottom:16px}
.e-desc{font-size:15px;color:rgba(245,240,232,0.5);line-height:1.7;font-style:italic}

/* ── CONCERT ── */
#concert{
  background:var(--near-black);
  position:relative;overflow:hidden;
}
#concert::before{
  content:'ARIA';
  position:absolute;right:-40px;top:50%;
  transform:translateY(-50%) rotate(90deg);
  font-family:'Playfair Display',serif;
  font-size:300px;font-weight:900;font-style:italic;
  color:rgba(201,168,76,0.03);
  pointer-events:none;white-space:nowrap;
  user-select:none;
}

.concert-layout{
  display:grid;grid-template-columns:1fr 1fr;gap:80px;
  align-items:start;
}
.concert-left{}
.concert-body{
  font-size:18px;line-height:2;
  color:rgba(245,240,232,0.6);margin-bottom:48px;
}
.program-showcase{
  border:1px solid rgba(201,168,76,0.2);
  padding:40px;
  background:rgba(201,168,76,0.03);
}
.program-label{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.4em;color:var(--gold);
  margin-bottom:8px;
}
.program-title{
  font-family:'Playfair Display',serif;
  font-size:24px;font-style:italic;font-weight:700;
  color:var(--white);margin-bottom:24px;line-height:1.2;
}
.program-chapters{
  list-style:none;display:flex;flex-direction:column;gap:0;
}
.program-chapter{
  padding:16px 0;
  border-bottom:1px solid rgba(201,168,76,0.1);
}
.program-chapter:last-child{border-bottom:none}
.chapter-name{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.3em;color:var(--gold);margin-bottom:4px;
}
.chapter-works{
  font-size:14px;color:rgba(245,240,232,0.5);
  line-height:1.6;font-style:italic;
}

.concert-right{}
.credentials-stack{
  display:flex;flex-direction:column;gap:2px;
}
.cred-item{
  background:rgba(245,240,232,0.02);
  border:1px solid rgba(201,168,76,0.08);
  padding:24px 28px;
  transition:border-color 0.3s,background 0.3s;
  display:flex;align-items:center;gap:20px;
}
.cred-item:hover{
  border-color:rgba(201,168,76,0.25);
  background:rgba(201,168,76,0.03);
}
.cred-dot{
  width:6px;height:6px;background:var(--gold);
  border-radius:50%;flex-shrink:0;
}
.cred-text{}
.cred-org{
  font-family:'Playfair Display',serif;
  font-size:16px;font-weight:700;
  color:var(--white);display:block;margin-bottom:2px;
}
.cred-detail{
  font-size:13px;color:var(--mid);font-style:italic;
}

/* ── REPERTOIRE ── */
#repertoire{
  background:var(--black);
}
.rep-intro{
  text-align:center;max-width:700px;
  margin:0 auto 80px;
  font-size:18px;font-style:italic;
  color:rgba(245,240,232,0.5);line-height:1.9;
}
.rep-tabs{
  display:flex;gap:0;margin-bottom:2px;
  border-bottom:1px solid rgba(201,168,76,0.15);
}
.rep-tab{
  font-family:'Cormorant SC',serif;font-size:10px;
  letter-spacing:0.35em;color:rgba(245,240,232,0.4);
  padding:16px 32px;cursor:pointer;
  border-bottom:2px solid transparent;
  transition:all 0.3s;background:none;border-top:none;border-left:none;border-right:none;
}
.rep-tab:hover{color:var(--gold)}
.rep-tab.active{color:var(--gold);border-bottom-color:var(--gold)}
.rep-panel{display:none}
.rep-panel.active{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.rep-group{
  background:rgba(245,240,232,0.02);
  border:1px solid rgba(201,168,76,0.08);
  padding:36px 32px;
}
.rep-group-name{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.4em;color:var(--gold);
  margin-bottom:20px;padding-bottom:16px;
  border-bottom:1px solid rgba(201,168,76,0.15);
}
.rep-items{list-style:none;display:flex;flex-direction:column;gap:12px}
.rep-item{font-size:15px;color:rgba(245,240,232,0.6);line-height:1.4}
.rep-composer{display:block;font-size:12px;color:var(--mid);font-style:italic;margin-top:2px}
.rep-bespoke{
  grid-column:1/-1;
  background:rgba(201,168,76,0.05);
  border:1px solid rgba(201,168,76,0.2);
  border-left:3px solid var(--gold);
  padding:32px 40px;margin-top:2px;
  font-size:17px;font-style:italic;
  color:rgba(245,240,232,0.6);line-height:1.8;
}
.rep-bespoke strong{color:var(--gold);font-style:normal}

/* ── CONTACT ── */
#contact{
  background:var(--near-black);
  position:relative;overflow:hidden;
}
#contact::after{
  content:'';position:absolute;
  bottom:-200px;left:50%;transform:translateX(-50%);
  width:800px;height:400px;
  background:radial-gradient(ellipse,rgba(201,168,76,0.08),transparent 70%);
  pointer-events:none;
}

.contact-layout{
  display:grid;grid-template-columns:1fr 1fr;
  gap:80px;align-items:start;
}
.contact-left{}
.contact-body{
  font-size:18px;line-height:2;
  color:rgba(245,240,232,0.6);margin-bottom:48px;
}
.contact-info{display:flex;flex-direction:column;gap:20px}
.contact-info-item{
  display:flex;align-items:center;gap:16px;
}
.contact-info-icon{
  width:40px;height:40px;
  border:1px solid rgba(201,168,76,0.3);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
}
.contact-info-icon svg{width:16px;height:16px;stroke:var(--gold);fill:none;stroke-width:1.5}
.contact-info-text{}
.contact-info-label{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.3em;color:var(--gold);
  display:block;margin-bottom:2px;
}
.contact-info-value{
  font-size:16px;color:rgba(245,240,232,0.7);
}
.contact-info-value a{color:inherit;text-decoration:none;transition:color 0.3s}
.contact-info-value a:hover{color:var(--gold)}

.contact-right{}
.inquiry-form{display:flex;flex-direction:column;gap:2px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.form-group{display:flex;flex-direction:column}
.form-label{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.35em;color:var(--gold);
  padding:12px 16px 0;
  background:rgba(245,240,232,0.03);
  border:1px solid rgba(201,168,76,0.1);
  border-bottom:none;
}
.form-input,.form-select,.form-textarea{
  background:rgba(245,240,232,0.03);
  border:1px solid rgba(201,168,76,0.1);
  border-top:none;
  color:var(--cream);
  font-family:'Cormorant Garamond',serif;
  font-size:17px;
  padding:12px 16px 16px;
  outline:none;
  transition:border-color 0.3s,background 0.3s;
  width:100%;
}
.form-input:focus,.form-select:focus,.form-textarea:focus{
  border-color:rgba(201,168,76,0.4);
  background:rgba(201,168,76,0.04);
}
.form-select{appearance:none;cursor:pointer}
.form-select option{background:var(--dark)}
.form-textarea{height:140px;resize:vertical;font-style:italic}
.form-submit{
  font-family:'Cormorant SC',serif;font-size:11px;
  letter-spacing:0.4em;color:var(--black);
  background:var(--gold);border:none;
  padding:20px;cursor:pointer;
  transition:background 0.3s,transform 0.2s;
  margin-top:2px;
}
.form-submit:hover{background:var(--gold2);transform:translateY(-1px)}

/* ── FOOTER ── */
footer{
  background:var(--black);
  padding:60px 48px 40px;
  border-top:1px solid rgba(201,168,76,0.1);
  text-align:center;
}
.footer-logo{
  font-family:'Playfair Display',serif;
  font-size:48px;font-style:italic;font-weight:900;
  color:var(--gold);margin-bottom:8px;
}
.footer-tagline{
  font-family:'Cormorant SC',serif;font-size:10px;
  letter-spacing:0.5em;color:var(--mid);
  margin-bottom:32px;
}
.footer-links{
  display:flex;gap:32px;justify-content:center;
  list-style:none;margin-bottom:40px;flex-wrap:wrap;
}
.footer-links a{
  font-family:'Cormorant SC',serif;font-size:9px;
  letter-spacing:0.3em;color:var(--mid);
  text-decoration:none;transition:color 0.3s;
}
.footer-links a:hover{color:var(--gold)}
.footer-copy{
  font-size:13px;color:rgba(106,90,58,0.5);
  font-style:italic;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(32px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes fadeIn{
  from{opacity:0}to{opacity:1}
}

.reveal{
  opacity:0;transform:translateY(40px);
  transition:opacity 0.8s ease,transform 0.8s ease;
}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── GOLD DIVIDER ── */
.gold-divider{
  display:flex;align-items:center;justify-content:center;
  gap:20px;margin:0 0 64px;
}
.gold-divider-line{
  flex:1;max-width:200px;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold));
}
.gold-divider-line.r{background:linear-gradient(90deg,var(--gold),transparent)}
.gold-divider-gem{width:8px;height:8px;background:var(--gold);transform:rotate(45deg)}

/* responsive */
@media(max-width:768px){
  nav{padding:20px 24px}
  .nav-links{display:none}
  section{padding:80px 24px}
  .about-grid,.concert-layout,.contact-layout{grid-template-columns:1fr}
  .rep-panel.active{grid-template-columns:1fr}
  .ensemble-add,.form-row{grid-template-columns:1fr}
  .w-pkg{grid-template-columns:1fr}
  .hero-title{font-size:clamp(48px,12vw,80px)}
}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- NAV -->
<nav id="navbar">
  <a href="#home" class="nav-logo">ARIA AMORE</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#wedding">Weddings</a></li>
    <li><a href="#concert">Concerts</a></li>
    <li><a href="#repertoire">Repertoire</a></li>
  </ul>
  <a href="#contact" class="nav-cta"><span>Book Now</span></a>
</nav>

<!-- HERO -->
<section id="home">
  <div class="hero-bg"></div>
  <div class="hero-lines"></div>
  <div class="hero-content">
    <p class="hero-pretitle">Charleston, South Carolina · Sopranist Countertenor</p>
    <h1 class="hero-title">
      <span class="outline">Aria</span><br>
      <span class="gold">Amore</span>
    </h1>
    <p class="hero-subtitle">Xavier Williams · A voice unlike anything you have ever heard</p>
    <div class="hero-divider">
      <div class="hero-divider-line"></div>
      <div class="hero-divider-gem"></div>
      <div class="hero-divider-line right"></div>
    </div>
    <div class="hero-buttons">
      <a href="#wedding" class="btn-primary"><span>Wedding Performances</span></a>
      <a href="#concert" class="btn-ghost">Concert Programs</a>
    </div>
  </div>
  <div class="scroll-indicator">
    <span>Scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="section-inner">
    <div class="about-grid">
      <div class="about-image-frame reveal">
        <div class="about-image-box">
          <img src="data:image/jpeg;base64," alt="Xavier Williams" style="width:100%;height:100%;object-fit:cover;object-position:center top;position:absolute;inset:0;">
        </div>
      </div>
      <div class="about-text reveal">
        <span class="overline">The Artist</span>
        <h2 class="section-title">Xavier<br><em>Williams</em></h2>
        <div class="gold-divider" style="justify-content:flex-start;margin-bottom:32px;">
          <div class="gold-divider-line" style="max-width:60px;"></div>
          <div class="gold-divider-gem"></div>
        </div>
        <p class="about-body">Xavier Williams is one of a rare breed — a sopranist countertenor whose voice inhabits the ethereal upper register of the male voice with power, precision, and unmistakable artistry. Based in Charleston, South Carolina, Xavier performs under the banner of Aria Amore, bringing intimate, story-driven vocal experiences to concert halls, sacred spaces, and the most discerning wedding celebrations.</p>
        <ul class="about-credentials">
          <li>American Spiritual Ensemble — Roster Artist</li>
          <li>National Chorale at Lincoln Center — Roster Artist, 2025</li>
          <li>Berlin Opera Academy — Accepted, 2025</li>
          <li>Charleston Opera Theater — Don Giovanni, L'elisir d'amore, La Bohème</li>
          <li>NATS — 1st Place District &amp; State · 2nd Place National</li>
          <li>MONCA Gene Ferguson Encouragement Award</li>
          <li>Meistersinger Competition Finalist — Graz, Austria</li>
          <li>Recent Performances — College of Charleston · Spoleto Festival USA</li>
        </ul>
        <a href="#contact" class="btn-primary" style="display:inline-block;margin-top:8px;"><span>Inquire About Booking</span></a>
        <div class="about-stat-row">
          <div class="about-stat">
            <div class="about-stat-num">5+</div>
            <div class="about-stat-label">Opera Roles</div>
          </div>
          <div class="about-stat">
            <div class="about-stat-num">3</div>
            <div class="about-stat-label">National Rosters</div>
          </div>
          <div class="about-stat">
            <div class="about-stat-num">75</div>
            <div class="about-stat-label">Min. Full Program</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- WEDDING -->
<section id="wedding">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:16px" class="reveal">
      <span class="overline">Wedding Performances</span>
      <h2 class="section-title">Your wedding deserves<br>an <em>extraordinary</em> <span class="outline">moment</span></h2>
    </div>
    <div class="gold-divider reveal"><div class="gold-divider-line"></div><div class="gold-divider-gem"></div><div class="gold-divider-line r"></div></div>
    <div class="wedding-hero-text reveal">
      <p>A countertenor voice is unlike anything most guests have ever heard at a wedding. Ethereal, powerful, and unmistakably rare — it transforms a ceremony into something no one in the room will ever forget. Every Aria Amore performance is built entirely around you and the story of your day.</p>
    </div>

    <div class="reveal" style="margin-bottom:48px;position:relative;height:340px;overflow:hidden;border:1px solid rgba(201,168,76,0.15);">
      <img src="data:image/jpeg;base64," alt="Xavier Williams" style="width:100%;height:100%;object-fit:cover;object-position:center 15%;filter:brightness(0.7);">
      <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(8,6,4,0.8) 0%,rgba(8,6,4,0.2) 60%,transparent 100%);display:flex;align-items:center;padding:60px;">
        <div>
          <div style="font-family:Cormorant SC,serif;font-size:10px;letter-spacing:0.5em;color:var(--gold);margin-bottom:12px;">Aria Amore</div>
          <div style="font-family:Playfair Display,serif;font-size:clamp(28px,4vw,48px);font-style:italic;font-weight:700;color:var(--white);line-height:1.1;max-width:480px;">A voice unlike anything your guests have ever heard</div>
        </div>
      </div>
    </div>

    <div class="wedding-packages reveal">
      <div class="w-pkg">
        <div class="w-pkg-left">
          <div class="w-pkg-tier">The Prelude</div>
          <div class="w-pkg-name">Ceremony Solo</div>
          <div class="w-pkg-price"><sup>$</sup>1,500 <small>starting</small></div>
        </div>
        <div class="w-pkg-right">
          <p class="w-pkg-desc">One singer. One voice. One unforgettable moment as you walk down the aisle.</p>
          <ul class="w-pkg-includes">
            <li>Up to 60 minutes of performance — prelude, processional, recessional</li>
            <li>Up to 3 curated selections from the Aria Amore repertoire</li>
            <li>One complimentary consultation to design your musical vision</li>
            <li>Collaborative pianist included</li>
          </ul>
        </div>
      </div>

      <div class="w-pkg featured">
        <div class="w-pkg-left">
          <div class="most-requested">Most Requested</div>
          <div class="w-pkg-tier">The Aria</div>
          <div class="w-pkg-name">Ceremony &amp; Cocktail Hour</div>
          <div class="w-pkg-price"><sup>$</sup>2,800 <small>starting</small></div>
        </div>
        <div class="w-pkg-right">
          <p class="w-pkg-desc">From the moment guests arrive through the first golden hour of celebration — a seamless arc of live music that sets the tone for everything that follows.</p>
          <ul class="w-pkg-includes">
            <li>Full ceremony performance — prelude, processional, recessional</li>
            <li>45-minute cocktail hour set — classical, crossover, or a blend</li>
            <li>Up to 8 selections across both sets</li>
            <li>Two consultations to curate your full program</li>
            <li>Collaborative pianist included</li>
            <li>One bespoke song request honored with advance notice</li>
          </ul>
        </div>
      </div>

      <div class="w-pkg">
        <div class="w-pkg-left">
          <div class="w-pkg-tier">The Grand Amore</div>
          <div class="w-pkg-name">Full Day Experience</div>
          <div class="w-pkg-price"><sup>$</sup>4,500 <small>starting</small></div>
        </div>
        <div class="w-pkg-right">
          <p class="w-pkg-desc">The complete experience. Live music woven through every chapter of your wedding day.</p>
          <ul class="w-pkg-includes">
            <li>Ceremony, cocktail hour, and one reception set</li>
            <li>Up to 4 hours of performance time across the day</li>
            <li>Unlimited repertoire consultations and 2 bespoke requests</li>
            <li>Collaborative pianist included</li>
            <li>Direct coordination with your wedding planner</li>
            <li>Priority booking and contract within 48 hours</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="ensemble-add reveal">
      <div class="ensemble-card">
        <div class="e-role">Add a Second Voice · Contralto</div>
        <div class="e-name">Rich &amp; Warm</div>
        <div class="e-price">+ $800</div>
        <p class="e-desc">A deep, warm lower voice paired with Xavier's ethereal upper register creates a vocal contrast that is genuinely breathtaking. Ideal for sacred duets and operatic pairings.</p>
      </div>
      <div class="ensemble-card">
        <div class="e-role">Add a Second Voice · Bass Baritone</div>
        <div class="e-name">Deep &amp; Commanding</div>
        <div class="e-price">+ $800</div>
        <p class="e-desc">The full depth of the male voice anchored against the brilliance of a countertenor — a combination almost never heard outside of professional opera. Sacred and operatic repertoire.</p>
      </div>
    </div>

    <div style="text-align:center;margin-top:48px" class="reveal">
      <a href="#contact" class="btn-primary"><span>Inquire About Your Date</span></a>
    </div>
  </div>
</section>

<!-- CONCERT -->
<section id="concert">
  <div class="section-inner">
    <div class="reveal" style="margin-bottom:64px;">
      <span class="overline">Concert &amp; Recital Programs</span>
      <h2 class="section-title"><em>Dreams of Freedom</em><br><span class="outline">Black Voices</span> in American Song</h2>
    </div>

    <div class="concert-layout">
      <div class="concert-left reveal">
        <p class="concert-body">A 75-minute recital program presenting five essential Black composers — Florence Price, Margaret Bonds, William Grant Still, H. Leslie Adams, and Moses Hogan — organized into four emotional chapters that trace the arc of Black American musical identity from the spiritual tradition through the concert art song canon.</p>
        <p class="concert-body">Spoken transitions connect each work to its historical and cultural context, making the experience as meaningful for first-time classical audiences as for seasoned concertgoers. Available for universities, cultural institutions, churches, and performing arts centers throughout South Carolina and beyond.</p>
        <a href="#contact" class="btn-ghost" style="display:inline-block;">Book This Program</a>

        <div class="program-showcase" style="margin-top:48px;">
          <div class="program-label">Current Touring Program</div>
          <div class="program-title">Dreams of Freedom: Black Voices in American Song</div>
          <ul class="program-chapters">
            <li class="program-chapter">
              <div class="chapter-name">Part One · Earth and Water</div>
              <div class="chapter-works">Florence Price — Night · Song to the Dark Virgin</div>
            </li>
            <li class="program-chapter">
              <div class="chapter-name">Part Two · Dreams and Identity</div>
              <div class="chapter-works">Margaret Bonds — Three Dream Portraits</div>
            </li>
            <li class="program-chapter">
              <div class="chapter-name">Part Three · The Lyric Voice</div>
              <div class="chapter-works">H. Leslie Adams — Five Millay Songs</div>
            </li>
            <li class="program-chapter">
              <div class="chapter-name">Part Four · The Praying Voice</div>
              <div class="chapter-works">Still · Hogan · Corley Spirituals</div>
            </li>
          </ul>
        </div>
      </div>

      <div class="concert-right reveal">
        <div class="credentials-stack">
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">American Spiritual Ensemble</span>
              <span class="cred-detail">Roster Artist</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">National Chorale at Lincoln Center</span>
              <span class="cred-detail">Roster Artist, 2025</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">Berlin Opera Academy</span>
              <span class="cred-detail">Accepted, 2025</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">Charleston Opera Theater</span>
              <span class="cred-detail">Don Giovanni · L'elisir d'amore · La Bohème</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">College of Charleston</span>
              <span class="cred-detail">Recent Performance — Deliverance: Spirituals &amp; Testimony</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">Spoleto Festival USA</span>
              <span class="cred-detail">Concert Performances, 2024</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">NATS Competition</span>
              <span class="cred-detail">1st Place District &amp; State · 2nd Place National</span>
            </div>
          </div>
          <div class="cred-item">
            <div class="cred-dot"></div>
            <div class="cred-text">
              <span class="cred-org">Meistersinger Competition</span>
              <span class="cred-detail">Finalist — Graz, Austria</span>
            </div>
          </div>
        </div>

        <div style="margin-top:32px;padding:32px;background:rgba(201,168,76,0.05);border:1px solid rgba(201,168,76,0.15);">
          <div style="font-family:'Cormorant SC',serif;font-size:9px;letter-spacing:0.4em;color:var(--gold);margin-bottom:16px;">Presenter Fees</div>
          <div style="display:flex;flex-direction:column;gap:10px;">
            <div style="display:flex;justify-content:space-between;font-size:15px;color:rgba(245,240,232,0.6);padding-bottom:10px;border-bottom:1px solid rgba(201,168,76,0.1);">
              <span>Universities &amp; HBCUs</span><span style="color:var(--gold);">$2,500 – $4,000</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:15px;color:rgba(245,240,232,0.6);padding-bottom:10px;border-bottom:1px solid rgba(201,168,76,0.1);">
              <span>Cultural Institutions</span><span style="color:var(--gold);">$1,500 – $3,000</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:15px;color:rgba(245,240,232,0.6);padding-bottom:10px;border-bottom:1px solid rgba(201,168,76,0.1);">
              <span>Performing Arts Centers</span><span style="color:var(--gold);">$3,000 – $6,000</span>
            </div>
            <div style="display:flex;justify-content:space-between;font-size:15px;color:rgba(245,240,232,0.6);">
              <span>Faith Communities</span><span style="color:var(--gold);">$500 – $1,500</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- REPERTOIRE -->
<section id="repertoire">
  <div class="section-inner">
    <div style="text-align:center;margin-bottom:16px" class="reveal">
      <span class="overline">Repertoire</span>
      <h2 class="section-title">The <em>Voice</em> Speaks<br><span class="outline">Many Languages</span></h2>
    </div>
    <div class="gold-divider reveal"><div class="gold-divider-line"></div><div class="gold-divider-gem"></div><div class="gold-divider-line r"></div></div>
    <div class="reveal" style="margin-bottom:48px;position:relative;height:300px;overflow:hidden;">
      <img src="data:image/jpeg;base64," alt="Xavier Williams performing" style="width:100%;height:100%;object-fit:cover;object-position:center 30%;filter:brightness(0.6);">
      <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(8,6,4,0.3),rgba(8,6,4,0.8));"></div>
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
        <div style="text-align:center;">
          <div style="font-family:Playfair Display,serif;font-size:clamp(32px,5vw,64px);font-style:italic;font-weight:900;color:rgba(201,168,76,0.9);-webkit-text-stroke:1px rgba(201,168,76,0.3);">"Absolutely beautiful"</div>
          <div style="font-family:Cormorant SC,serif;font-size:10px;letter-spacing:0.5em;color:rgba(245,240,232,0.5);margin-top:12px;">— Lauryn Kay · Audience Member</div>
        </div>
      </div>
    </div>

    <p class="rep-intro reveal">From the grandeur of Handel to the quiet power of a Moses Hogan spiritual — every piece selected for the voice, the occasion, and the story that needs telling.</p>

    <div class="rep-tabs reveal">
      <button class="rep-tab active" onclick="showTab('baroque')">Baroque &amp; Classical</button>
      <button class="rep-tab" onclick="showTab('sacred')">Sacred &amp; Devotional</button>
      <button class="rep-tab" onclick="showTab('american')">American Art Song</button>
      <button class="rep-tab" onclick="showTab('crossover')">Crossover &amp; Surprise</button>
    </div>

    <div id="tab-baroque" class="rep-panel active">
      <div class="rep-group">
        <div class="rep-group-name">Handel</div>
        <ul class="rep-items">
          <li class="rep-item">Ombra mai fu<span class="rep-composer">Xerxes</span></li>
          <li class="rep-item">Lascia ch'io pianga<span class="rep-composer">Rinaldo</span></li>
          <li class="rep-item">Cara sposa<span class="rep-composer">Rinaldo</span></li>
          <li class="rep-item">Se pieta di me non senti<span class="rep-composer">Giulio Cesare</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Vivaldi &amp; Bach</div>
        <ul class="rep-items">
          <li class="rep-item">Nulla in mundo pax sincera<span class="rep-composer">Vivaldi</span></li>
          <li class="rep-item">Stabat Mater — excerpt<span class="rep-composer">Vivaldi</span></li>
          <li class="rep-item">Agnus Dei<span class="rep-composer">Bach · Mass in B Minor</span></li>
          <li class="rep-item">Erbarme dich<span class="rep-composer">Bach · St. Matthew Passion</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Purcell &amp; Others</div>
        <ul class="rep-items">
          <li class="rep-item">Music for a While<span class="rep-composer">Purcell</span></li>
          <li class="rep-item">When I am laid in earth<span class="rep-composer">Purcell · Dido &amp; Aeneas</span></li>
        </ul>
      </div>
      <div class="rep-bespoke">
        <strong>Bespoke requests welcome.</strong> Have a specific aria or art song in mind? Reach out and ask — the answer is almost always yes with sufficient advance notice.
      </div>
    </div>

    <div id="tab-sacred" class="rep-panel">
      <div class="rep-group">
        <div class="rep-group-name">Classical Sacred</div>
        <ul class="rep-items">
          <li class="rep-item">Ave Maria<span class="rep-composer">Schubert · Bach/Gounod</span></li>
          <li class="rep-item">Panis Angelicus<span class="rep-composer">Franck</span></li>
          <li class="rep-item">The Lord's Prayer<span class="rep-composer">Malotte</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Spirituals</div>
        <ul class="rep-items">
          <li class="rep-item">Give Me Jesus<span class="rep-composer">arr. Moses Hogan</span></li>
          <li class="rep-item">He's Got the Whole World<span class="rep-composer">arr. Moses Hogan</span></li>
          <li class="rep-item">I Want Jesus to Walk With Me<span class="rep-composer">arr. Thompson Corley</span></li>
          <li class="rep-item">Lord I Want to Be a Christian<span class="rep-composer">arr. Thompson Corley</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Hymns &amp; Contemporary</div>
        <ul class="rep-items">
          <li class="rep-item">Be Thou My Vision<span class="rep-composer">Traditional Hymn</span></li>
          <li class="rep-item">How Beautiful<span class="rep-composer">Twila Paris</span></li>
        </ul>
      </div>
      <div class="rep-bespoke">
        <strong>Sacred repertoire is Xavier's native language.</strong> From ancient liturgy to contemporary gospel — if it belongs in a house of worship or a moment of reverence, it belongs in this voice.
      </div>
    </div>

    <div id="tab-american" class="rep-panel">
      <div class="rep-group">
        <div class="rep-group-name">Florence Price</div>
        <ul class="rep-items">
          <li class="rep-item">Night<span class="rep-composer">text: Louise C. Wallace</span></li>
          <li class="rep-item">Song to the Dark Virgin<span class="rep-composer">text: Langston Hughes</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Margaret Bonds</div>
        <ul class="rep-items">
          <li class="rep-item">Three Dream Portraits<span class="rep-composer">text: Langston Hughes</span></li>
          <li class="rep-item">The Negro Speaks of Rivers<span class="rep-composer">text: Langston Hughes</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Still · Adams · Hogan</div>
        <ul class="rep-items">
          <li class="rep-item">Grief<span class="rep-composer">William Grant Still</span></li>
          <li class="rep-item">Five Millay Songs<span class="rep-composer">H. Leslie Adams</span></li>
        </ul>
      </div>
      <div class="rep-bespoke">
        <strong>Centering Black composers is not a programming choice — it is an artistic conviction.</strong> This repertoire is the backbone of the Aria Amore concert mission.
      </div>
    </div>

    <div id="tab-crossover" class="rep-panel">
      <div class="rep-group">
        <div class="rep-group-name">The Surprise Pieces</div>
        <ul class="rep-items">
          <li class="rep-item">Pure Imagination<span class="rep-composer">Leslie Bricusse</span></li>
          <li class="rep-item">Somewhere Over the Rainbow<span class="rep-composer">Harold Arlen</span></li>
          <li class="rep-item">La Vie en Rose<span class="rep-composer">Édith Piaf</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Musical Theater</div>
        <ul class="rep-items">
          <li class="rep-item">Being Alive<span class="rep-composer">Sondheim · Company</span></li>
          <li class="rep-item">If I Loved You<span class="rep-composer">Rodgers &amp; Hammerstein</span></li>
          <li class="rep-item">Somewhere<span class="rep-composer">Bernstein · West Side Story</span></li>
          <li class="rep-item">Sun and Moon<span class="rep-composer">Schönberg · Miss Saigon</span></li>
        </ul>
      </div>
      <div class="rep-group">
        <div class="rep-group-name">Till There Was You</div>
        <ul class="rep-items">
          <li class="rep-item">Till There Was You<span class="rep-composer">Meredith Willson</span></li>
          <li class="rep-item">All I Ask of You<span class="rep-composer">Lloyd Webber · on request</span></li>
        </ul>
      </div>
      <div class="rep-bespoke">
        <strong>A countertenor singing Pure Imagination stops a cocktail hour cold.</strong> These pieces are chosen because they do something unexpected in this voice — and the room never forgets it.
      </div>
    </div>
  </div>
</section>

<!-- CONTACT -->
<section id="contact">
  <div class="section-inner">
    <div class="contact-layout">
      <div class="contact-left reveal">
        <span class="overline">Booking &amp; Inquiries</span>
        <h2 class="section-title">Let's create<br>something <em>extraordinary</em></h2>
        <div class="gold-divider" style="justify-content:flex-start;margin-bottom:32px;">
          <div class="gold-divider-line" style="max-width:60px;"></div>
          <div class="gold-divider-gem"></div>
        </div>
        <p class="contact-body">Whether you are planning a wedding, presenting a concert series, or exploring what Aria Amore might bring to your stage — reach out. All inquiries receive a personal response within 24 hours.</p>
        <div class="contact-info">
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact-info-text">
              <span class="contact-info-label">Email</span>
              <span class="contact-info-value"><a href="mailto:aria.amore.events@gmail.com">aria.amore.events@gmail.com</a></span>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div class="contact-info-text">
              <span class="contact-info-label">Website</span>
              <span class="contact-info-value"><a href="http://ariaamore.com">ariaamore.com</a></span>
            </div>
          </div>
          <div class="contact-info-item">
            <div class="contact-info-icon">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact-info-text">
              <span class="contact-info-label">Based In</span>
              <span class="contact-info-value">Charleston, South Carolina</span>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-right reveal">
        <div class="inquiry-form">
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">First Name</label>
              <input class="form-input" type="text" placeholder="Your name">
            </div>
            <div class="form-group">
              <label class="form-label">Last Name</label>
              <input class="form-input" type="text" placeholder="Your name">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Email Address</label>
            <input class="form-input" type="email" placeholder="your@email.com">
          </div>
          <div class="form-group">
            <label class="form-label">Type of Inquiry</label>
            <select class="form-select form-input">
              <option value="">Select one</option>
              <option>Wedding Performance</option>
              <option>Concert or Recital Booking</option>
              <option>University or Institution</option>
              <option>Church or Faith Community</option>
              <option>Other</option>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label class="form-label">Event Date</label>
              <input class="form-input" type="text" placeholder="MM / DD / YYYY">
            </div>
            <div class="form-group">
              <label class="form-label">Event Location</label>
              <input class="form-input" type="text" placeholder="City, Venue">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">Tell Me About Your Vision</label>
            <textarea class="form-textarea" placeholder="Share whatever feels relevant — the occasion, the feeling you want to create, pieces you love, anything at all..."></textarea>
          </div>
          <button class="form-submit">Send Inquiry</button>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">Aria Amore</div>
  <div class="footer-tagline">Xavier Williams · Sopranist Countertenor · Charleston, South Carolina</div>
  <ul class="footer-links">
    <li><a href="#about">About</a></li>
    <li><a href="#wedding">Weddings</a></li>
    <li><a href="#concert">Concerts</a></li>
    <li><a href="#repertoire">Repertoire</a></li>
    <li><a href="#contact">Contact</a></li>
    <li><a href="mailto:aria.amore.events@gmail.com">aria.amore.events@gmail.com</a></li>
  </ul>
  <div class="footer-copy">© 2026 Aria Amore · Xavier Williams · All Rights Reserved</div>
</footer>

<script>
// Custom cursor
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cursor.style.left=mx+'px';cursor.style.top=my+'px';
});
function animateRing(){
  rx+=(mx-rx)*0.12;ry+=(my-ry)*0.12;
  ring.style.left=rx+'px';ring.style.top=ry+'px';
  requestAnimationFrame(animateRing);
}
animateRing();
document.querySelectorAll('a,button,.rep-tab').forEach(el=>{
  el.addEventListener('mouseenter',()=>{
    cursor.style.width='20px';cursor.style.height='20px';
    ring.style.width='60px';ring.style.height='60px';
  });
  el.addEventListener('mouseleave',()=>{
    cursor.style.width='12px';cursor.style.height='12px';
    ring.style.width='40px';ring.style.height='40px';
  });
});

// Nav scroll
const navbar = document.getElementById('navbar');
window.addEventListener('scroll',()=>{
  navbar.classList.toggle('scrolled',window.scrollY>60);
});

// Reveal on scroll
const reveals = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries)=>{
  entries.forEach((e,i)=>{
    if(e.isIntersecting){
      setTimeout(()=>e.target.classList.add('visible'),i*80);
    }
  });
},{threshold:0.1});
reveals.forEach(r=>observer.observe(r));

// Repertoire tabs
function showTab(id){
  document.querySelectorAll('.rep-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.rep-panel').forEach(p=>p.classList.remove('active'));
  document.querySelector(`[onclick="showTab('${id}')"]`).classList.add('active');
  document.getElementById('tab-'+id).classList.add('active');
}

// Form submit
document.querySelector('.form-submit').addEventListener('click',function(){
  this.textContent='Inquiry Sent ✦';
  this.style.background='#8B6914';
  setTimeout(()=>{
    this.textContent='Send Inquiry';
    this.style.background='';
  },3000);
});
</script>
</body>
</html>
